# Django settings
DEBUG=True
SECRET_KEY=change-me-to-a-real-secret-key

# Brevo (Sendinblue) email settings
BREVO_API_KEY=your-brevo-api-key-here
DEFAULT_FROM_EMAIL=noreply@example.com

# Zoom settings
ZOOM_ACCOUNT_ID=your-zoom-account-id-here
ZOOM_CLIENT_ID=your-zoom-client-id-here
ZOOM_CLIENT_SECRET=your-zoom-client-secret-here
# Zoom registrant import is disabled by default. Set to "true" to re-enable
# the "Import Zoom Registrants" admin button and the underlying action.
ZOOM_REGISTRATION_ENABLED=false

# Production settings (Railway)
# ALLOWED_HOSTS=your-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SITE_URL=https://your-app.up.railway.app
