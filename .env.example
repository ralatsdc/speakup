# SpeakUp configuration — copy to .env for local dev, or set each variable
# in the Railway dashboard (Service → Variables) for production. The
# bootstrap runbook is at docs/railway-setup.md.
#
# Required-in-production variables are marked [REQUIRED]. Variables marked
# [DEFAULT] have a working fallback in config/settings.py and are optional.

# --- Django core ---------------------------------------------------------

# [REQUIRED in prod] Long random string. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=change-me-to-a-real-secret-key

# [DEFAULT] False/unset for production; True for local dev.
DEBUG=True

# [REQUIRED in prod] Comma-separated. Include the Railway domain and any
# custom domain pointed at the service.
# ALLOWED_HOSTS=speakup.up.railway.app,speakupcambridge.example

# [REQUIRED in prod] Comma-separated scheme+host. Used by CSRF middleware.
# CSRF_TRUSTED_ORIGINS=https://speakup.up.railway.app

# [REQUIRED in prod] Auto-provided by Railway's Postgres plugin under this
# exact name. Local dev defaults to SQLite at db.sqlite3 when unset.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# [REQUIRED in prod] Public origin used for absolute links in outbound
# email (meeting reminders, role guides, etc.).
# SITE_URL=https://speakup.up.railway.app

# --- Email (Brevo / Anymail) --------------------------------------------

# [REQUIRED in prod] Created in the Brevo dashboard → SMTP & API → API Keys.
BREVO_API_KEY=your-brevo-api-key-here

# [DEFAULT] From address on every outbound email. Must be a Brevo-verified
# sender. Falls back to noreply@speakup.com if unset.
DEFAULT_FROM_EMAIL=noreply@example.com

# --- S3 / role-guide storage --------------------------------------------
# When AWS_STORAGE_BUCKET_NAME is set, FileFields (e.g. Role.guidance_document)
# write to the named S3 bucket. Leave blank to use local MEDIA_ROOT — fine for
# dev, not for Railway (the filesystem there is ephemeral).
# See docs/railway-setup.md → "S3 bucket and IAM user" for the one-time setup
# and the policy JSON.

# [REQUIRED in prod] Bucket name (Block Public Access ON, no public policy).
# AWS_STORAGE_BUCKET_NAME=speakup-club-media

# [DEFAULT] us-east-1 if unset.
# AWS_S3_REGION_NAME=us-east-1

# [REQUIRED when AWS_STORAGE_BUCKET_NAME is set] Access key for an IAM user
# scoped to the bucket only (see runbook).
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# --- Zoom (currently disabled) -------------------------------------------
# All four variables are optional. The integration is gated off by default;
# flip ZOOM_REGISTRATION_ENABLED to "true" to re-enable.
ZOOM_ACCOUNT_ID=your-zoom-account-id-here
ZOOM_CLIENT_ID=your-zoom-client-id-here
ZOOM_CLIENT_SECRET=your-zoom-client-secret-here
ZOOM_REGISTRATION_ENABLED=false
