# Credentials for postgres/pg.sh. Copy to postgres/.env and fill in the
# values. The .env file is sourced by pg.sh and parsed by send_dump.py.
# Never commit a real .env — see docs/railway-setup.md for guidance.

# --- Railway Postgres connection ----------------------------------------
# Found under Railway → Postgres service → Variables. The same values
# `pg_dump` / `pg_restore` accept via -h / -p / -d / -U flags.
PGHOST=shuttle.proxy.rlwy.net
PGPORT=47835
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=<your-pg-password>

# --- Backup mailbox (Gmail) --------------------------------------------
# Optional. When BACKUP_EMAIL_TO is set, pg.sh -d emails each new dump
# to the listed address(es). Leave BACKUP_EMAIL_TO blank to skip the
# email step — the local tar is always written either way.
#
# Two-account model:
#   BACKUP_EMAIL_FROM         — sender. A developer-owned Gmail with
#                               2SV enabled. Officers never touch it.
#   BACKUP_EMAIL_APP_PASSWORD — App password for the sender account
#                               (NOT the human Gmail password).
#   BACKUP_EMAIL_TO           — recipient(s). Comma-separated. Typically
#                               a shared club mailbox (no 2SV) that
#                               officers can sign in to.
#
# See docs/railway-setup.md → "Backup mailbox (Gmail)" for the one-time
# account + App-password setup.

BACKUP_EMAIL_FROM=
BACKUP_EMAIL_APP_PASSWORD=
BACKUP_EMAIL_TO=
